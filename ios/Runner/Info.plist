<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>EvairSIM</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>evair_sim</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UIStatusBarHidden</key>
		<false/>
		<!--
			Declare the 'remote-notification' background mode so iOS will
			wake the app when a silent / data-only push arrives with
			`content-available: 1`. Our PushService sets that flag on
			every send (see config/push.php) so foreground handling gets
			a chance to run even when the user has the app in background.
		-->
		<key>UIBackgroundModes</key>
		<array>
			<string>remote-notification</string>
			<string>fetch</string>
		</array>
		<!--
			FirebaseAppDelegateProxyEnabled=NO tells Firebase Messaging
			NOT to swizzle the AppDelegate automatically. The Flutter
			runner delegate already forwards UIApplicationDelegate
			callbacks to registered plugins, so we opt out of the
			method-swizzle and keep the delegate chain explicit. Do not
			remove this key without first reading
			https://firebase.flutter.dev/docs/messaging/apple-integration.
		-->
		<key>FirebaseAppDelegateProxyEnabled</key>
		<false/>
		<key>NSCameraUsageDescription</key>
		<string>EvairSIM uses the camera to scan QR codes on the back of your SIM card when activating a physical SIM.</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>EvairSIM needs access to your photo library so you can save your eSIM QR code for later scanning.</string>
		<!--
			iOS 14+ requires this string whenever an app accesses the
			local network (e.g. the WebView shell pointing at the dev
			Mac's 192.168.x.y Vite server). Without it, iOS silently
			terminates the app on first local-network access. In
			production the app talks only to evair.zhhwxt.cn so this
			prompt never surfaces to end users.
		-->
		<key>NSLocalNetworkUsageDescription</key>
		<string>EvairSIM connects to the development server on your local network while testing. This only applies during development.</string>
		<!--
			Dev-only ATS exceptions. The WebView shell points at a Vite dev
			server on the developer's Mac (e.g. 192.168.3.82:3000) when
			launched with `--dart-define=H5_URL=http://<mac-ip>:3000`.
			Production traffic stays on https://evair.zhhwxt.cn which does
			NOT need any exception.

			`NSAllowsLocalNetworking` is Apple's official flag for "permit
			cleartext traffic on local/private networks". It allows
			connections to any RFC 1918 private IP (10.*, 172.16-31.*,
			192.168.*) plus .local and link-local, which is what we need
			for hot-reload development against a laptop. Public HTTP URLs
			remain blocked by the default ATS policy.
		-->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<false/>
			<key>NSAllowsLocalNetworking</key>
			<true/>
			<key>NSExceptionDomains</key>
			<dict>
				<key>localhost</key>
				<dict>
					<key>NSExceptionAllowsInsecureHTTPLoads</key>
					<true/>
					<key>NSIncludesSubdomains</key>
					<true/>
				</dict>
			</dict>
		</dict>
		<!--
			Schemes the APP can open via url_launcher / share_plus. Without
			these entries iOS 9+ silently blocks opening mail / dialler /
			whatsapp from H5's `window.evair.openExternal(...)`.
		-->
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>tel</string>
			<string>sms</string>
			<string>mailto</string>
			<string>http</string>
			<string>https</string>
			<string>whatsapp</string>
		</array>
	</dict>
</plist>
